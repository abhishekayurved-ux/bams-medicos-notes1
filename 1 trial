            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* The Rounded Bar Styling */
        .subject-bar {
            display: block;
            background: white;
            color: #1c7c54;
            text-decoration: none;
            padding: 15px 20px;
            margin-bottom: 12px;
            border-radius: 50px; /* This creates the "Pill" shape */
            border: 2px solid #1c7c54;
            font-weight: bold;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        /* Changes color when student clicks/hovers */
        .subject-bar:hover {
            background: #1c7c54;
            color: white;
            transform: translateY(-2px);
        }

        footer {
            background: #1c7c54;
            color: white;
            padding: 25px;
            margin-top: 50px;
        }

        .footer-link {
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .footer-link img {
            background: white;
            border-radius: 5px;
            padding: 2px;
        }
