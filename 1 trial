        /* This section makes the "Green Bars" and "Rounded" design work */
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4fbf4; /* Light herbal white */
            text-align: center;
